# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# Application
DEBUG=false
MAX_FILE_SIZE_MB=20

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ONNX Models
ONNX_NER_MODEL=dslim/bert-base-NER
ONNX_CLASSIFICATION_MODEL=typeform/distilbert-base-uncased-mnli
